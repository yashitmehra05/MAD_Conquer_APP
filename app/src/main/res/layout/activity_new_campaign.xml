<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/text_white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Create Campaign"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Fill in the details to launch your campaign"
                android:textColor="@color/text_grey"
                android:textSize="14sp" />

            <!-- Campaign Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Campaign Name"
                android:textColor="@color/text_grey"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etCampaignName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_field"
                android:hint="Summer Collection 2024"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_grey"
                android:textSize="14sp" />

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="⊙  Category"
                android:textColor="@color/text_grey"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etCategory"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_field"
                android:hint="e.g. Fashion, Tech, Food"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_grey"
                android:textSize="14sp" />

            <!-- Budget -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="$  Budget"
                android:textColor="@color/text_grey"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etBudget"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_field"
                android:hint="$ 5000"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_grey"
                android:textSize="14sp" />

            <!-- Start Date / End Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="📅  Start Date                    End Date"
                android:textColor="@color/text_grey"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etStartDate"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_field"
                    android:hint="DD/MM/YYYY"
                    android:inputType="date"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_grey"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etEndDate"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_field"
                    android:hint="DD/MM/YYYY"
                    android:inputType="date"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_grey"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Campaign Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="📋  Campaign Description"
                android:textColor="@color/text_grey"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top|start"
                android:hint="Describe your campaign goals and vision..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_grey"
                android:textSize="14sp" />

            <!-- Deliverables -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="☑  Deliverables"
                android:textColor="@color/text_grey"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etDeliverables"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top|start"
                android:hint="E.g., 3 Instagram posts, 2 stories, 1 reel"
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_grey"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:text="Cancel"
            android:textColor="@color/text_white"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnCreateCampaign"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/gradient_button"
            android:text="Create Campaign"
            android:textColor="@color/text_white"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>